SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# Repository paths are resolved from the repository root by default.
PYTHON_BIN=python
GENERATE_SERVER_SCRIPT=src/generate_server.py
CHECKPOINT_PATH=checkpoints/best.pt
TOKENIZER_PATH=tokenizer/yowa_yousei_sp.model

# Optional generation defaults applied when launching the server process.
MAX_NEW_TOKENS=200
TEMPERATURE=0.8
TOP_P=0.9
TOP_K=0
DEVICE=auto
STOP_AT_EOS=false

# How long to wait for the generation server to load the checkpoint.
READY_TIMEOUT_MS=180000
# Per-request generation timeout. On timeout the server is restarted.
GENERATION_TIMEOUT_MS=300000
